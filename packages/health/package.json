{
  "name": "@reactive-agents/health",
  "version": "0.10.6",
  "description": "Health checks and readiness probes for Reactive Agents production deployments",
  "keywords": [
    "ai",
    "agents",
    "ai-agents",
    "llm",
    "effect-ts",
    "typescript",
    "health-check",
    "readiness",
    "liveness",
    "probe",
    "production"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup --config ../../tsup.config.base.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test --reporter=dots"
  },
  "dependencies": {
    "@reactive-agents/runtime-shim": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "bun-types": "latest",
    "effect": "^3.10.0"
  },
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tylerjrbuell/reactive-agents-ts.git",
    "directory": "packages/health"
  },
  "homepage": "https://docs.reactiveagents.dev/",
  "bugs": {
    "url": "https://github.com/tylerjrbuell/reactive-agents-ts/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "effect": "^3.10.0"
  }
}
