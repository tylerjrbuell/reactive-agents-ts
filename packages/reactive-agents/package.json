{
  "name": "reactive-agents",
  "version": "0.9.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "rax": "bin/rax.js",
    "reactive-agents": "bin/rax.js"
  },
  "description": "The composable AI agent framework built on Effect-TS \u2014 install everything with one package",
  "keywords": [
    "ai",
    "agents",
    "llm",
    "effect-ts",
    "typescript",
    "ai-agents",
    "autonomous-agents",
    "react-loop",
    "guardrails",
    "agent-framework",
    "multi-agent",
    "mcp",
    "model-context-protocol",
    "ollama",
    "a2a",
    "observability",
    "reasoning"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tylerjrbuell/reactive-agents-ts.git",
    "directory": "packages/reactive-agents"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@reactive-agents/core": "0.9.0",
    "@reactive-agents/runtime": "0.9.0",
