    "@reactive-agents/interaction": "0.9.0",
    "@reactive-agents/orchestration": "0.9.0",
    "@reactive-agents/prompts": "0.9.0",
    "@reactive-agents/eval": "0.9.0",
    "@reactive-agents/a2a": "0.9.0",
    "@reactive-agents/cli": "0.9.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "bun-types": "latest",
    "effect": "^3.10.0"
  },
