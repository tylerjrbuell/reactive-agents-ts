    "@reactive-agents/reasoning": "0.9.0",
    "@reactive-agents/tools": "0.9.0",
    "@reactive-agents/guardrails": "0.9.0",
    "@reactive-agents/verification": "0.9.0",
    "@reactive-agents/cost": "0.9.0",
