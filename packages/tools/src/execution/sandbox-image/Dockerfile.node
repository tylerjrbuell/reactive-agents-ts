# rax-sandbox:node — Hardened Node.js code execution sandbox
# Same security model as Dockerfile.bun — minimal Alpine + non-root.

FROM node:22-alpine3.22 AS build
RUN node --version

# ── Runtime stage ────────────────────────────────────────────────────────────
FROM alpine:3.22 AS runtime

COPY --from=build /usr/local/bin/node /usr/local/bin/node

# Alpine already has nobody:nobody at uid/gid 65534 — use it directly
RUN apk add --no-cache libgcc libstdc++ && \
    mkdir -p /workspace /tmp && \
    chown 65534:65534 /workspace /tmp && \
    chmod 1777 /tmp && \
    chmod 700 /workspace && \
    rm -rf /var/cache/apk /etc/apk /usr/share/apk /sbin/apk && \
    rm -f /bin/sh /bin/ash /bin/busybox

USER 65534:65534
WORKDIR /workspace

ENTRYPOINT ["/usr/local/bin/node"]
