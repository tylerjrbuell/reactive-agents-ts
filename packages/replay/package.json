{
  "name": "@reactive-agents/replay",
  "version": "0.10.6",
  "description": "Deterministic re-run of recorded reactive-agent traces with prompt/model overrides",
  "keywords": [
    "ai",
    "agents",
    "ai-agents",
    "llm",
    "effect-ts",
    "typescript",
    "replay",
    "trace",
    "deterministic",
    "snapshot",
    "testing",
    "debugging"
  ],
  "type": "module",
  "scripts": {
    "build": "tsup --config ../../tsup.config.base.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test --reporter=dots",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@reactive-agents/core": "workspace:*",
    "@reactive-agents/trace": "workspace:*",
    "@reactive-agents/tools": "workspace:*",
    "effect": "^3.10.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "bun-types": "latest"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tylerjrbuell/reactive-agents-ts.git",
    "directory": "packages/replay"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "homepage": "https://docs.reactiveagents.dev/",
  "bugs": {
    "url": "https://github.com/tylerjrbuell/reactive-agents-ts/issues"
  }
}
