{
  "name": "@reactive-agents/reactive-intelligence",
  "version": "0.10.6",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup --config ../../tsup.config.base.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test --reporter=dots",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@reactive-agents/core": "workspace:*",
    "@reactive-agents/llm-provider": "workspace:*",
    "@reactive-agents/runtime-shim": "workspace:*",
    "@reactive-agents/trace": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "bun-types": "latest",
    "effect": "^3.10.0"
  },
  "license": "MIT",
  "engines": {
    "bun": ">=1.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tylerjrbuell/reactive-agents-ts.git",
    "directory": "packages/reactive-intelligence"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "description": "Reactive Intelligence layer for Reactive Agents — entropy sensing, adaptive control, and learning",
  "keywords": [
    "ai",
    "agents",
    "ai-agents",
    "llm",
    "effect-ts",
    "typescript",
    "metacognition",
    "entropy",
    "adaptive-control",
    "bandit",
    "self-improving",
    "reactive-intelligence"
  ],
  "homepage": "https://docs.reactiveagents.dev/",
  "bugs": {
    "url": "https://github.com/tylerjrbuell/reactive-agents-ts/issues"
  },
  "peerDependencies": {
    "effect": "^3.10.0"
  }
}
