    "@reactive-agents/tools": "0.10.0",
    "@reactive-agents/trace": "0.10.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "bun-types": "latest",
    "effect": "^3.10.0"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
