{
  "name": "@reactive-agents/testing",
  "version": "0.10.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup --config ../../tsup.config.base.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test --reporter=dots",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@reactive-agents/core": "0.10.0",
    "@reactive-agents/llm-provider": "0.10.0",
