{
  "name": "@reactive-agents/trace",
  "version": "0.10.6",
  "description": "Structured execution trace recording and inspection for Reactive Agents",
  "keywords": [
    "ai",
    "agents",
    "ai-agents",
    "llm",
    "effect-ts",
    "typescript",
    "trace",
    "tracing",
    "jsonl",
    "observability",
    "debugging"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup --config ../../tsup.config.base.ts && tsup src/normalize.ts --format esm --dts --sourcemap --out-dir dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test --reporter=dots"
  },
  "dependencies": {
    "@reactive-agents/core": "workspace:*",
    "@reactive-agents/observability": "workspace:*",
    "effect": "^3.10.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "bun-types": "latest",
    "tsup": "*"
  },
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./normalize": {
      "bun": "./dist/normalize.js",
      "types": "./dist/normalize.d.ts",
      "import": "./dist/normalize.js",
      "default": "./dist/normalize.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tylerjrbuell/reactive-agents-ts.git",
    "directory": "packages/trace"
  },
  "homepage": "https://docs.reactiveagents.dev/",
  "bugs": {
    "url": "https://github.com/tylerjrbuell/reactive-agents-ts/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "effect": "^3.10.0"
  }
}
