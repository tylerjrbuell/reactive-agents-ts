{
  "name": "reactive-agents",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*",
    "apps/*",
    "apps/cortex/ui"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter='./packages/*'",
    "build:apps": "turbo run build --filter='./apps/*'",
    "build:clean": "CLEAN=true turbo run build --force",
    "test": "turbo run test",
    "smoke": "cd apps/examples && bun run smoke",
    "smoke:strict": "cd apps/examples && bun run smoke:strict",
    "test:watch": "bun test --reporter=dots --watch",
    "typecheck": "turbo run typecheck",
    "lint": "eslint 'packages/**/*.ts' 'apps/**/*.ts'",
    "clean": "find packages apps -name 'dist' -type d -exec rm -rf {} + 2>/dev/null || true && rm -rf .turbo && CLEAN=true turbo run build --force",
    "cortex": "bun run apps/cortex/scripts/dev-stack.ts",
    "rax": "bun ./apps/cli/src/index.ts",
    "rax:diagnose": "bun ./packages/diagnose/src/cli.ts",
    "probe:ollama-fc": "bun .agents/skills/harness-improvement-loop/scripts/ollama-native-fc-context-probe.ts",
    "probe:ollama-fc:replay": "PROBE_SCENARIOS=replay-failing-thread-shape PROBE_REPEATS=3 bun .agents/skills/harness-improvement-loop/scripts/ollama-native-fc-context-probe.ts",
    "probe:ollama-fc:gate": "bun .agents/skills/harness-improvement-loop/scripts/ollama-native-fc-gate.ts",
    "bench:t0": "bun test packages/benchmarks/tests/t0-deterministic.test.ts",
    "gate:check": "bun test packages/testing/tests/gate/north-star-gate.test.ts --timeout 60000",
    "gate:update": "bun scripts/gate-update.ts",
    "gate:explain": "bun scripts/gate-explain.ts",
    "gate:health": "bun scripts/gate-health.ts",
    "gate:propose": "bun scripts/gate-propose.ts",
    "docs:dev": "cd apps/docs && bun x astro dev",
    "docs:build": "cd apps/docs && bun x astro build",
    "docs:preview": "cd apps/docs && bun x astro preview",
    "changeset": "changeset",
    "release": "bun scripts/release.ts",
    "release:dry": "bun scripts/release.ts --dry-run",
    "test:install": "bun scripts/test-clean-install.ts"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tylerjrbuell/reactive-agents-ts.git"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.13",
    "@typescript-eslint/parser": "^8.59.4",
    "bun-types": "^1.3.13",
    "eslint": "^9",
    "tsup": "^8.5.1",
    "turbo": "^2.9.9",
    "typescript": "^6.0.3"
  }
}