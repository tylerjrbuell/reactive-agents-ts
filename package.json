{
  "name": "reactive-agents",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*",
    "apps/*",
    "apps/cortex/ui"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter='./packages/*'",
    "build:apps": "turbo run build --filter='./apps/*'",
    "build:clean": "CLEAN=true turbo run build --force",
    "test": "turbo run test",
    "test:watch": "bun test --watch",
    "typecheck": "turbo run typecheck",
    "clean": "find packages apps -name 'dist' -type d -exec rm -rf {} + 2>/dev/null || true && rm -rf .turbo && CLEAN=true turbo run build --force",
    "rax": "bun ./apps/cli/src/index.ts",
    "probe:ollama-fc": "bun .agents/skills/harness-improvement-loop/scripts/ollama-native-fc-context-probe.ts",
    "probe:ollama-fc:replay": "PROBE_SCENARIOS=replay-failing-thread-shape PROBE_REPEATS=3 bun .agents/skills/harness-improvement-loop/scripts/ollama-native-fc-context-probe.ts",
    "probe:ollama-fc:gate": "bun .agents/skills/harness-improvement-loop/scripts/ollama-native-fc-gate.ts",
    "docs:dev": "cd apps/docs && bun x astro dev",
    "docs:build": "cd apps/docs && bun x astro build",
    "docs:preview": "cd apps/docs && bun x astro preview",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && node scripts/resolve-workspace-deps.mjs && changeset publish"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tylerjrbuell/reactive-agents-ts.git"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/bun": "^1.3.9",
    "bun-types": "latest",
    "tsup": "^8.5.1",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  }
}