{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "static/**",
        "svelte.config.*",
        "vite.config.*",
        "tailwind.config.*",
        "postcss.config.*",
        "tsconfig.json",
        "package.json"
      ],
      "outputs": ["build/**", ".svelte-kit/**"]
    }
  }
}
