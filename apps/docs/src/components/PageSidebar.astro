---
/**
 * Right-hand page sidebar override. Renders Starlight's default "On this page"
 * table of contents, then appends the release-subscribe form so it is visible
 * on every docs page without cluttering the article body.
 */
import type { Props } from "@astrojs/starlight/props";
import Default from "@astrojs/starlight/components/PageSidebar.astro";
import EmailSubscribe from "./EmailSubscribe.astro";
---

<Default {...Astro.props}><slot /></Default>

<div class="ra-sidebar-subscribe">
    <EmailSubscribe sidebar />
</div>
