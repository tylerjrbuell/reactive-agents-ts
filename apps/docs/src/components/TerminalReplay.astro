---
/**
 * TerminalReplay — animated terminal that replays `rax demo` output.
 * Each frame appears with realistic timing. Click to restart.
 */
---

<div class="terminal-replay" id="terminal-replay">
  <div class="terminal-header">
    <div class="terminal-dots">
      <span class="dot dot-red"></span>
      <span class="dot dot-yellow"></span>
      <span class="dot dot-green"></span>
    </div>
    <span class="terminal-title">rax demo</span>
    <button class="terminal-restart" id="terminal-restart" title="Replay">↻</button>
  </div>
  <div class="terminal-body" id="terminal-body">
    <div class="terminal-prompt" id="terminal-prompt">
      <span class="prompt-symbol">$</span> <span class="prompt-cmd" id="terminal-cmd"></span><span class="cursor" id="terminal-cursor">▋</span>
    </div>
    <pre class="terminal-output" id="terminal-output"></pre>
  </div>
</div>

<style>
  .terminal-replay {
    overflow: hidden;
    background: #0d1117;
    font-family: "Geist Mono", "JetBrains Mono", "Fira Code", "SF Mono", Menlo, monospace;
  }

  .terminal-header {
    display: flex;
    align-items: center;
    padding: 10px 14px;
    background: #161b22;
    border-bottom: 1px solid rgba(139, 92, 246, 0.1);
    user-select: none;
  }

  .terminal-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot-red { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green { background: #28c840; }

  .terminal-title {
    flex: 1;
    text-align: center;
    font-size: 0.75rem;
    color: #6b7280;
    letter-spacing: 0.03em;
  }

  .terminal-restart {
    background: none;
    border: 1px solid rgba(139, 92, 246, 0.2);
    color: #8b5cf6;
    font-size: 0.85rem;
    cursor: pointer;
    border-radius: 4px;
    padding: 2px 8px;
    transition: all 0.2s ease;
    line-height: 1;
  }

  .terminal-restart:hover {
    background: rgba(139, 92, 246, 0.1);
    border-color: #8b5cf6;
  }

  .terminal-body {
    padding: 16px;
    min-height: 380px;
    max-height: 520px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(139, 92, 246, 0.2) transparent;
  }

  .terminal-prompt {
    color: #e6edf3;
    font-size: 0.82rem;
    line-height: 1.5;
    margin-bottom: 4px;
  }

  .prompt-symbol {
    color: #8b5cf6;
    font-weight: 700;
  }

  .prompt-cmd {
    color: #06b6d4;
  }

  .cursor {
    color: #8b5cf6;
    animation: blink 1s step-end infinite;
  }

  .cursor.hidden { display: none; }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .terminal-output {
    margin: 0;
    padding: 0;
    color: #e6edf3;
    font-size: 0.75rem;
    line-height: 1.55;
    white-space: pre-wrap;
    word-break: break-word;
    background: none;
    border: none;
    font-family: inherit;
  }

  /* Color classes for the output */
  .terminal-output :global(.t-violet) { color: #8b5cf6; }
  .terminal-output :global(.t-cyan) { color: #06b6d4; }
  .terminal-output :global(.t-green) { color: #22c55e; }
  .terminal-output :global(.t-yellow) { color: #eab308; }
  .terminal-output :global(.t-dim) { color: #6b7280; }
  .terminal-output :global(.t-bold) { font-weight: 700; }
  .terminal-output :global(.t-white) { color: #e6edf3; }

  /* Spinner animation */
  .terminal-output :global(.t-spinner) {
    color: #8b5cf6;
    display: inline;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .terminal-replay { margin: 1rem 0; }
    .terminal-body { min-height: 300px; max-height: 420px; padding: 12px; }
    .terminal-output { font-size: 0.65rem; }
  }
</style>

<script>
  // Terminal replay frames — each frame is [delay_ms, html_content]
  // The content uses span classes for coloring
  const FRAMES: [number, string][] = [
    // Banner
    [300, `<span class="t-violet">╭──────────────────────────────────────────────────────────╮</span>`],
    [30, `<span class="t-violet">│</span>`],
    [30, `<span class="t-violet">│</span>   <span class="t-violet t-bold">Reactive Agents — Live Demo</span>`],
    [30, `<span class="t-violet">│</span>   <span class="t-dim">The open-source agent framework built for control,</span>`],
    [30, `<span class="t-violet">│</span>   <span class="t-dim">not magic.</span>`],
    [30, `<span class="t-violet">│</span>`],
    [30, `<span class="t-violet">╰──────────────────────────────────────────────────────────╯</span>`],
    [200, ``],

    // Task
    [100, `<span class="t-violet t-bold">🎯 Task</span>`],
    [80, `  <span class="t-dim">Prompt:</span> Use the get-hn-posts tool to fetch the top 5 stories on Hacker News right now,`],
    [50, `          then write them as a numbered list. Finish with a one-paragraph summary.`],
    [150, `  <span class="t-dim">Provider:</span> <span class="t-cyan">Anthropic · claude-haiku-4-5</span>`],
    [80, `  <span class="t-dim">Mode:</span> <span class="t-green">live agent run</span>`],
    [300, ``],

    // StatusRenderer live output — real tool call against HN
    [400, `<span class="t-violet">◉</span> <span class="t-bold">demo-agent</span> <span class="t-dim">· ReAct · claude-haiku-4-5</span>`],
    [100, `<span class="t-dim">│</span>`],
    [500, `<span class="t-dim">│</span> <span class="t-violet">💭</span> <span class="t-dim">I need to fetch the current Hacker News front page. The</span>`],
    [80, `<span class="t-dim">│</span>    <span class="t-dim">get-hn-posts tool is the right primitive — calling it now.</span>`],
    [100, `<span class="t-dim">│</span>`],
    [400, `<span class="t-dim">│</span> <span class="t-cyan">⚙</span>  <span class="t-bold">tool</span> <span class="t-cyan">get-hn-posts</span><span class="t-dim">({ count: 5 })</span>`],
    [600, `<span class="t-dim">│</span> <span class="t-green">↪</span>  <span class="t-dim">5 stories returned · 412ms</span>`],
    [100, `<span class="t-dim">│</span>`],
    [500, `<span class="t-dim">│</span> <span class="t-violet">💭</span> <span class="t-dim">Got the live data. Formatting the numbered list with</span>`],
    [80, `<span class="t-dim">│</span>    <span class="t-dim">title + score + url, then synthesizing the trend summary.</span>`],
    [100, `<span class="t-dim">│</span>`],
    [400, `<span class="t-dim">└─</span> <span class="t-green">✔ Done</span> <span class="t-dim">· 3 steps · 1 tool · 1284 tokens · 4.1s</span>`],
    [300, ``],

    // Agent response — note that real runs return whatever's currently
    // trending; this is a representative snapshot.
    [100, `<span class="t-cyan">╭─ Agent ──────────────────────────────────────────────────╮</span>`],
    [30, `<span class="t-cyan">│</span> <span class="t-bold">## Hacker News — Top 5 (live)</span>`],
    [30, `<span class="t-cyan">│</span>`],
    [30, `<span class="t-cyan">│</span> 1. <span class="t-bold">Show HN: I built a search engine for arXiv papers</span>`],
    [30, `<span class="t-cyan">│</span>    <span class="t-yellow">412 points</span> <span class="t-dim">· news.ycombinator.com/item?id=39024716</span>`],
    [30, `<span class="t-cyan">│</span> 2. <span class="t-bold">The hidden cost of context-switching in distributed teams</span>`],
    [30, `<span class="t-cyan">│</span>    <span class="t-yellow">287 points</span> <span class="t-dim">· blog.example.com/context-switching</span>`],
    [30, `<span class="t-cyan">│</span> 3. <span class="t-bold">Why Effect-TS finally clicked for our backend</span>`],
    [30, `<span class="t-cyan">│</span>    <span class="t-yellow">251 points</span> <span class="t-dim">· hashnode.example.dev/effect-ts-clicked</span>`],
    [30, `<span class="t-cyan">│</span> 4. <span class="t-bold">A practical guide to writing your own database</span>`],
    [30, `<span class="t-cyan">│</span>    <span class="t-yellow">198 points</span> <span class="t-dim">· example.io/build-a-database</span>`],
    [30, `<span class="t-cyan">│</span> 5. <span class="t-bold">OpenAI releases new reasoning model: o4-mini</span>`],
    [30, `<span class="t-cyan">│</span>    <span class="t-yellow">173 points</span> <span class="t-dim">· openai.com/blog/o4-mini</span>`],
    [30, `<span class="t-cyan">│</span>`],
    [30, `<span class="t-cyan">│</span> <span class="t-bold">Summary:</span> Today's HN front page is dominated by infrastructure`],
    [30, `<span class="t-cyan">│</span> and tooling — a self-built arXiv search, a write-your-own-database`],
    [30, `<span class="t-cyan">│</span> guide, and an Effect-TS adoption story all sit alongside an`],
    [30, `<span class="t-cyan">│</span> OpenAI reasoning-model release. Trends technical and DIY.`],
    [30, `<span class="t-cyan">╰──────────────────────────────────────────────────────────╯</span>`],
    [300, ``],

    // Metrics — tools count is now real (1)
    [100, `<span class="t-green">✔</span> 4.1s · 3 steps · 1284 tokens · 1 tool`],
    [300, ``],

    // CTA
    [100, `<span class="t-dim">──────────────────────────────────────────────────</span>`],
    [100, ``],
    [100, `<span class="t-violet t-bold">🚀 Liked what you saw?</span>`],
    [100, ``],
    [80, `  <span class="t-dim">Install:</span> <span class="t-cyan">bun add reactive-agents</span>`],
    [80, `  <span class="t-dim">Scaffold:</span> <span class="t-cyan">rax init my-agent</span>`],
  ];

  function initTerminalReplay() {
    const output = document.getElementById('terminal-output');
    const cmd = document.getElementById('terminal-cmd');
    const cursor = document.getElementById('terminal-cursor');
    const restart = document.getElementById('terminal-restart');
    const body = document.getElementById('terminal-body');
    if (!output || !cmd || !cursor || !restart || !body) return;

    let abortController: AbortController | null = null;

    async function typeCommand(text: string, signal: AbortSignal) {
      cmd!.textContent = '';
      for (let i = 0; i < text.length; i++) {
        if (signal.aborted) return;
        cmd!.textContent += text[i];
        await sleep(60 + Math.random() * 40, signal);
      }
      await sleep(400, signal);
      cursor!.classList.add('hidden');
    }

    async function playFrames(signal: AbortSignal) {
      output!.innerHTML = '';
      for (const [delay, html] of FRAMES) {
        if (signal.aborted) return;
        await sleep(delay, signal);
        if (signal.aborted) return;
        output!.innerHTML += html + '\n';
        body!.scrollTop = body!.scrollHeight;
      }
    }

    function sleep(ms: number, signal?: AbortSignal): Promise<void> {
      return new Promise((resolve, reject) => {
        if (signal?.aborted) { reject(new DOMException('Aborted', 'AbortError')); return; }
        const id = setTimeout(resolve, ms);
        signal?.addEventListener('abort', () => { clearTimeout(id); reject(new DOMException('Aborted', 'AbortError')); }, { once: true });
      });
    }

    async function run() {
      if (abortController) abortController.abort();
      abortController = new AbortController();
      const signal = abortController.signal;

      output!.innerHTML = '';
      cmd!.textContent = '';
      cursor!.classList.remove('hidden');

      try {
        await typeCommand('rax demo', signal);
        await playFrames(signal);
      } catch (e) {
        if (e instanceof DOMException && e.name === 'AbortError') return;
      }
    }

    restart.addEventListener('click', () => run());

    // Auto-play when visible
    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        observer.disconnect();
        run();
      }
    }, { threshold: 0.3 });

    const terminal = document.getElementById('terminal-replay');
    if (terminal) observer.observe(terminal);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTerminalReplay);
  } else {
    requestAnimationFrame(initTerminalReplay);
  }
</script>
