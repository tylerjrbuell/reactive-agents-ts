---
/**
 * TerminalReplay — animated terminal that replays `rax demo` output.
 * Each frame appears with realistic timing. Click to restart.
 */
---

<div class="terminal-replay" id="terminal-replay">
  <div class="terminal-header">
    <div class="terminal-dots">
      <span class="dot dot-red"></span>
      <span class="dot dot-yellow"></span>
      <span class="dot dot-green"></span>
    </div>
    <span class="terminal-title">rax demo</span>
    <button class="terminal-restart" id="terminal-restart" title="Replay">↻</button>
  </div>
  <div class="terminal-body" id="terminal-body">
    <div class="terminal-prompt" id="terminal-prompt">
      <span class="prompt-symbol">$</span> <span class="prompt-cmd" id="terminal-cmd"></span><span class="cursor" id="terminal-cursor">▋</span>
    </div>
    <pre class="terminal-output" id="terminal-output"></pre>
  </div>
</div>

<style>
  .terminal-replay {
    max-width: auto;
    margin: 1.5rem auto 2rem;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(139, 92, 246, 0.2);
    background: #0d1117;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), 0 0 60px rgba(139, 92, 246, 0.06);
    font-family: "Geist Mono", "JetBrains Mono", "Fira Code", "SF Mono", Menlo, monospace;
  }

  .terminal-header {
    display: flex;
    align-items: center;
    padding: 10px 14px;
    background: #161b22;
    border-bottom: 1px solid rgba(139, 92, 246, 0.1);
    user-select: none;
  }

  .terminal-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot-red { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green { background: #28c840; }

  .terminal-title {
    flex: 1;
    text-align: center;
    font-size: 0.75rem;
    color: #6b7280;
    letter-spacing: 0.03em;
  }

  .terminal-restart {
    background: none;
    border: 1px solid rgba(139, 92, 246, 0.2);
    color: #8b5cf6;
    font-size: 0.85rem;
    cursor: pointer;
    border-radius: 4px;
    padding: 2px 8px;
    transition: all 0.2s ease;
    line-height: 1;
  }

  .terminal-restart:hover {
    background: rgba(139, 92, 246, 0.1);
    border-color: #8b5cf6;
  }

  .terminal-body {
    padding: 16px;
    min-height: 380px;
    max-height: 520px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(139, 92, 246, 0.2) transparent;
  }

  .terminal-prompt {
    color: #e6edf3;
    font-size: 0.82rem;
    line-height: 1.5;
    margin-bottom: 4px;
  }

  .prompt-symbol {
    color: #8b5cf6;
    font-weight: 700;
  }

  .prompt-cmd {
    color: #06b6d4;
  }

  .cursor {
    color: #8b5cf6;
    animation: blink 1s step-end infinite;
  }

  .cursor.hidden { display: none; }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .terminal-output {
    margin: 0;
    padding: 0;
    color: #e6edf3;
    font-size: 0.75rem;
    line-height: 1.55;
    white-space: pre-wrap;
    word-break: break-word;
    background: none;
    border: none;
    font-family: inherit;
  }

  /* Color classes for the output */
  .terminal-output :global(.t-violet) { color: #8b5cf6; }
  .terminal-output :global(.t-cyan) { color: #06b6d4; }
  .terminal-output :global(.t-green) { color: #22c55e; }
  .terminal-output :global(.t-yellow) { color: #eab308; }
  .terminal-output :global(.t-dim) { color: #6b7280; }
  .terminal-output :global(.t-bold) { font-weight: 700; }
  .terminal-output :global(.t-white) { color: #e6edf3; }

  /* Spinner animation */
  .terminal-output :global(.t-spinner) {
    color: #8b5cf6;
    display: inline;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .terminal-replay { margin: 1rem 0; }
    .terminal-body { min-height: 300px; max-height: 420px; padding: 12px; }
    .terminal-output { font-size: 0.65rem; }
  }
</style>

<script>
  // Terminal replay frames — each frame is [delay_ms, html_content]
  // The content uses span classes for coloring
  const FRAMES: [number, string][] = [
    // Banner (left-border only)
    [300, `<span class="t-violet">╭──────────────────────────────────────────────────────────</span>`],
    [30, `<span class="t-violet">│</span>`],
    [30, `<span class="t-violet">│</span>   <span class="t-violet t-bold">Reactive Agents — Live Demo</span>`],
    [30, `<span class="t-violet">│</span>   <span class="t-dim">The open-source agent framework built for control,</span>`],
    [30, `<span class="t-violet">│</span>   <span class="t-dim">not magic.</span>`],
    [30, `<span class="t-violet">│</span>`],
    [30, `<span class="t-violet">╰──────────────────────────────────────────────────────────</span>`],
    [200, ``],

    // Task
    [100, `<span class="t-violet t-bold">🎯 Task</span>`],
    [80, `  <span class="t-dim">Prompt:</span> Find the top 3 TypeScript testing frameworks and compare their features`],
    [150, `  <span class="t-dim">Provider:</span> test (deterministic, no API key needed)`],
    [80, `  <span class="t-dim">Mode:</span> direct LLM (scripted response)`],
    [300, ``],

    // Build
    [200, `<span class="t-violet">⠋</span> Building agent...`],
    [600, `<span class="t-green">✔</span> Agent ready`],
    [400, ``],

    // Execution steps
    [300, `<span class="t-violet">⠋</span> Running agent...`],
    [700, `<span class="t-violet">💭</span> <span class="t-dim">Step 1/3 — thinking...</span>`],
    [80, `   <span class="t-dim">Planning approach to research testing frameworks</span>`],
    [100, ``],
    [600, `<span class="t-violet">💭</span> <span class="t-dim">Step 2/3 — thinking...</span>`],
    [80, `   <span class="t-dim">Evaluating Vitest, Jest, Bun test runner...</span>`],
    [100, ``],
    [600, `<span class="t-violet">💭</span> <span class="t-dim">Step 3/3 — thinking...</span>`],
    [80, `   <span class="t-dim">Synthesizing comparison</span>`],
    [100, ``],
    [300, `<span class="t-green">✔</span> Completed in 2.8s`],
    [300, ``],

    // Agent response box (left-border only — avoids emoji width alignment issues)
    [100, `<span class="t-cyan">╭─ Agent ──────────────────────────────────────────────────</span>`],
    [30, `<span class="t-cyan">│</span> <span class="t-bold">## Top 3 TypeScript Testing Frameworks (2026)</span>`],
    [30, `<span class="t-cyan">│</span>`],
    [30, `<span class="t-cyan">│</span>  Framework     Speed        DX          TypeScript`],
    [30, `<span class="t-cyan">│</span>  ───────────   ──────────   ─────────   ──────────`],
    [30, `<span class="t-cyan">│</span>  <span class="t-bold">Vitest</span>        <span class="t-yellow">Fast</span>         Excellent   Native`],
    [30, `<span class="t-cyan">│</span>  <span class="t-bold">Bun Test</span>      <span class="t-yellow">Fastest</span>      Great       Native`],
    [30, `<span class="t-cyan">│</span>  <span class="t-bold">Jest</span>          Moderate     Good        Via ts-jest`],
    [30, `<span class="t-cyan">│</span>`],
    [30, `<span class="t-cyan">│</span> <span class="t-bold">Vitest</span> — Native ESM, Vite-powered HMR, Jest-compatible API.`],
    [30, `<span class="t-cyan">│</span> <span class="t-bold">Bun Test</span> — Fastest runner, zero-config TS, built into Bun.`],
    [30, `<span class="t-cyan">│</span> <span class="t-bold">Jest</span> — Largest ecosystem, mature plugins, needs ts-jest.`],
    [30, `<span class="t-cyan">│</span>`],
    [30, `<span class="t-cyan">│</span> <span class="t-bold">Recommendation:</span> Vitest for most TypeScript projects.`],
    [30, `<span class="t-cyan">╰──────────────────────────────────────────────────────────</span>`],
    [300, ``],

    // Dashboard (left-border only)
    [100, `<span class="t-green">╭─ Execution Summary ──────────────────────────────────────</span>`],
    [30, `<span class="t-green">│</span> <span class="t-bold">Status:</span>  <span class="t-green">✔ Success</span>   <span class="t-bold">Duration:</span> 2.8s   <span class="t-bold">Steps:</span> 3`],
    [30, `<span class="t-green">│</span> <span class="t-bold">Tokens:</span>  314         <span class="t-bold">Cost:</span> ~$0.0009    <span class="t-bold">Model:</span> test`],
    [30, `<span class="t-green">╰──────────────────────────────────────────────────────────</span>`],
    [200, ``],

    // Timeline
    [100, `<span class="t-bold">📊 Execution Timeline</span>`],
    [60, `├─ <span class="t-dim">[bootstrap]</span>              45ms  <span class="t-green">✔</span>  <span class="t-dim">2%</span>`],
    [60, `├─ <span class="t-dim">[strategy]</span>               30ms  <span class="t-green">✔</span>  <span class="t-dim">1%</span>`],
    [60, `├─ <span class="t-dim">[think]</span>               1,847ms  <span class="t-green">✔</span>  <span class="t-dim">65%</span> <span class="t-dim">(3 iterations)</span>`],
    [60, `└─ <span class="t-dim">[complete]</span>               15ms  <span class="t-green">✔</span>  <span class="t-dim">1%</span>`],
    [200, ``],
    [100, `<span class="t-green">✔</span> 2.8s · 3 steps · 314 tokens · 0 tools`],
    [300, ``],

    // CTA
    [100, `<span class="t-dim">──────────────────────────────────────────────────</span>`],
    [100, ``],
    [100, `<span class="t-violet t-bold">🚀 Liked what you saw?</span>`],
    [100, ``],
    [80, `  <span class="t-dim">Install:</span> <span class="t-cyan">bun add reactive-agents</span>`],
    [80, `  <span class="t-dim">Scaffold:</span> <span class="t-cyan">rax init my-agent --template standard</span>`],
  ];

  function initTerminalReplay() {
    const output = document.getElementById('terminal-output');
    const cmd = document.getElementById('terminal-cmd');
    const cursor = document.getElementById('terminal-cursor');
    const restart = document.getElementById('terminal-restart');
    const body = document.getElementById('terminal-body');
    if (!output || !cmd || !cursor || !restart || !body) return;

    let abortController: AbortController | null = null;

    async function typeCommand(text: string, signal: AbortSignal) {
      cmd!.textContent = '';
      for (let i = 0; i < text.length; i++) {
        if (signal.aborted) return;
        cmd!.textContent += text[i];
        await sleep(60 + Math.random() * 40, signal);
      }
      await sleep(400, signal);
      cursor!.classList.add('hidden');
    }

    async function playFrames(signal: AbortSignal) {
      output!.innerHTML = '';
      for (const [delay, html] of FRAMES) {
        if (signal.aborted) return;
        await sleep(delay, signal);
        if (signal.aborted) return;
        output!.innerHTML += html + '\n';
        body!.scrollTop = body!.scrollHeight;
      }
    }

    function sleep(ms: number, signal?: AbortSignal): Promise<void> {
      return new Promise((resolve, reject) => {
        if (signal?.aborted) { reject(new DOMException('Aborted', 'AbortError')); return; }
        const id = setTimeout(resolve, ms);
        signal?.addEventListener('abort', () => { clearTimeout(id); reject(new DOMException('Aborted', 'AbortError')); }, { once: true });
      });
    }

    async function run() {
      if (abortController) abortController.abort();
      abortController = new AbortController();
      const signal = abortController.signal;

      output!.innerHTML = '';
      cmd!.textContent = '';
      cursor!.classList.remove('hidden');

      try {
        await typeCommand('npx reactive-agents demo', signal);
        await playFrames(signal);
      } catch (e) {
        if (e instanceof DOMException && e.name === 'AbortError') return;
      }
    }

    restart.addEventListener('click', () => run());

    // Auto-play when visible
    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        observer.disconnect();
        run();
      }
    }, { threshold: 0.3 });

    const terminal = document.getElementById('terminal-replay');
    if (terminal) observer.observe(terminal);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTerminalReplay);
  } else {
    requestAnimationFrame(initTerminalReplay);
  }
</script>
