<style>
/* ── Wrapper & entrance ──────────────────────────────────────── */
.fc-wrap {
  margin: 0 auto 4rem;
  max-width: 980px;
  animation: fc-fade-up 0.55s ease-out 0.2s both;
}

@keyframes fc-fade-up {
  from { opacity: 0; transform: translateY(22px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── Gradient border shell ──────────────────────────────────── */
.fc-outer {
  padding: 1px;
  border-radius: 20px;
  background: linear-gradient(
    135deg,
    rgba(139, 92, 246, 0.6)  0%,
    rgba(6, 182, 212, 0.3)   50%,
    rgba(139, 92, 246, 0.6)  100%
  );
  box-shadow:
    0 0 0 1px rgba(139, 92, 246, 0.06),
    0 10px 40px rgba(0, 0, 0, 0.45),
    0 0 90px rgba(139, 92, 246, 0.07);
  animation: fc-glow 8s ease-in-out infinite;
}

@keyframes fc-glow {
  0%, 100% {
    box-shadow:
      0 0 0 1px rgba(139, 92, 246, 0.06),
      0 10px 40px rgba(0, 0, 0, 0.45),
      0 0 90px rgba(139, 92, 246, 0.07);
  }
  50% {
    box-shadow:
      0 0 0 1px rgba(6, 182, 212, 0.1),
      0 10px 40px rgba(0, 0, 0, 0.45),
      0 0 90px rgba(6, 182, 212, 0.09);
  }
}

/* ── Window card ─────────────────────────────────────────────── */
.fc-win {
  background: #12131a;
  border-radius: 19px;
  overflow: hidden;
}

/* ── Header / Tab strip ─────────────────────────────────────── */
.fc-header {
  background: rgba(139, 92, 246, 0.04);
  border-bottom: 1px solid rgba(139, 92, 246, 0.13);
  padding: 13px 20px 13px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fc-tabs {
  display: flex;
  gap: 5px;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
}

.fc-tab {
  appearance: none;
  -webkit-appearance: none;
  margin: 0;
  background: rgba(139, 92, 246, 0.04);
  border: 1px solid rgba(139, 92, 246, 0.1);
  border-radius: 999px;
  color: rgba(148, 163, 184, 0.6);
  cursor: pointer;
  font-family: inherit;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.01em;
  padding: 0 15px;
  height: 30px;
  min-height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  transition:
    background 0.18s ease,
    border-color 0.18s ease,
    color 0.18s ease;
  white-space: nowrap;
  flex-shrink: 0;
  box-sizing: border-box;
  vertical-align: middle;
}

.fc-tab:hover:not(.active) {
  background: rgba(139, 92, 246, 0.09);
  border-color: rgba(139, 92, 246, 0.22);
  color: rgba(196, 181, 253, 0.85);
}

.fc-tab.active {
  background: linear-gradient(
    135deg,
    rgba(139, 92, 246, 0.22) 0%,
    rgba(6, 182, 212, 0.1)   100%
  );
  border-color: rgba(139, 92, 246, 0.48);
  color: #c4b5fd;
}

/* ── Progress bar ────────────────────────────────────────────── */
.fc-prog-track {
  height: 2px;
  background: rgba(139, 92, 246, 0.08);
  overflow: hidden;
}

.fc-prog-fill {
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, #8b5cf6 0%, #06b6d4 100%);
  border-radius: 0 2px 2px 0;
}

.fc-prog-fill.running {
  animation: fc-prog-go 6s linear forwards;
}

@keyframes fc-prog-go {
  from { width: 0% }
  to   { width: 100% }
}

/* ── Panels ──────────────────────────────────────────────────── */
.fc-panels {
  position: relative;
}

.fc-panel {
  display: none;
}

.fc-panel.active {
  display: block;
  animation: fc-enter 0.3s ease forwards;
}

@keyframes fc-enter {
  from { opacity: 0; transform: translateY(5px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── Body — two-column split ─────────────────────────────────── */
.fc-body {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  padding: 26px 24px 28px;
  align-items: start;
}

/* ── Feature item grid ───────────────────────────────────────── */
.fc-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18px 20px;
}

.fc-item {
  display: flex;
  gap: 11px;
  align-items: flex-start;
}

.fc-icon {
  width: 34px;
  height: 34px;
  min-width: 34px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(139, 92, 246, 0.09);
  border: 1px solid rgba(139, 92, 246, 0.16);
  border-radius: 9px;
  font-size: 1.05rem;
  line-height: 1;
  transition: background 0.2s ease, border-color 0.2s ease;
}

.fc-item:hover .fc-icon {
  background: rgba(139, 92, 246, 0.17);
  border-color: rgba(139, 92, 246, 0.32);
}

.fc-name {
  font-size: 0.8rem;
  font-weight: 700;
  color: #dde2ee;
  margin: 0 0 3px;
  line-height: 1.3;
}

.fc-desc {
  font-size: 0.715rem;
  color: rgba(148, 163, 184, 0.75);
  margin: 0;
  line-height: 1.5;
}

/* ── Code box ────────────────────────────────────────────────── */
.fc-code-box {
  background: rgba(0, 0, 0, 0.28);
  border: 1px solid rgba(139, 92, 246, 0.12);
  border-radius: 12px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.fc-code-label {
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.13em;
  text-transform: uppercase;
  color: #06b6d4;
  opacity: 0.65;
  padding: 9px 15px 7px;
  border-bottom: 1px solid rgba(139, 92, 246, 0.08);
  flex-shrink: 0;
  margin: 0;
}

.fc-code {
  font-family: "Geist Mono", "Cascadia Code", "Fira Code", ui-monospace, monospace !important;
  font-size: 0.72rem !important;
  line-height: 1.72 !important;
  margin: 0 !important;
  padding: 14px 16px !important;
  overflow-x: auto;
  color: #c8d1e4 !important;
  white-space: pre !important;
  flex: 1;
  /* Override Starlight's expressive-code styles */
  background: transparent !important;
  border: none !important;
  border-radius: 0 !important;
}

/* Syntax token coloring */
.fc-code :global(.rk) { color: #c4b5fd; }
.fc-code :global(.rm) { color: #67e8f9; }
.fc-code :global(.rs) { color: #86efac; }
.fc-code :global(.rc) { color: #475569; font-style: italic; }
.fc-code :global(.rp) { color: #8892a4; }
.fc-code :global(.rn) { color: #fbbf24; }
.fc-code :global(.rg) { color: #4ade80; }
.fc-code :global(.ry) { color: #facc15; }
.fc-code :global(.ro) { color: #3d4a60; }

/* ── Responsive ──────────────────────────────────────────────── */
@media (max-width: 860px) {
  .fc-body {
    grid-template-columns: 1fr;
    gap: 20px;
  }
  .fc-grid {
    grid-template-columns: repeat(3, 1fr);
  }
  .fc-code-box {
    display: none;
  }
}

@media (max-width: 640px) {
  .fc-grid {
    grid-template-columns: 1fr 1fr;
  }
  .fc-tab {
    font-size: 0.74rem;
    padding: 0 10px;
    height: 28px;
  }
  .fc-header {
    padding: 12px 14px 10px;
  }
  .fc-body {
    padding: 20px 18px 22px;
  }
}

@media (max-width: 440px) {
  .fc-grid {
    grid-template-columns: 1fr;
  }
  .fc-tab {
    font-size: 0.7rem;
    padding: 0 8px;
    height: 26px;
  }
}

/* ── Light mode ──────────────────────────────────────────────── */
:global([data-theme="light"]) .fc-win {
  background: #f9f9fd;
}

:global([data-theme="light"]) .fc-outer {
  background: linear-gradient(
    135deg,
    rgba(109, 40, 217, 0.45) 0%,
    rgba(8, 145, 178, 0.28)  50%,
    rgba(109, 40, 217, 0.45) 100%
  );
  box-shadow:
    0 0 0 1px rgba(109, 40, 217, 0.1),
    0 4px 16px rgba(0, 0, 0, 0.1),
    0 12px 40px rgba(0, 0, 0, 0.12),
    0 0 60px rgba(109, 40, 217, 0.08);
  animation: none;
}

:global([data-theme="light"]) .fc-header {
  background: rgba(109, 40, 217, 0.03);
  border-bottom-color: rgba(109, 40, 217, 0.1);
}

:global([data-theme="light"]) .fc-tab {
  color: rgba(71, 85, 105, 0.65);
}

:global([data-theme="light"]) .fc-tab:hover:not(.active) {
  background: rgba(109, 40, 217, 0.06);
  border-color: rgba(109, 40, 217, 0.2);
  color: #5b21b6;
}

:global([data-theme="light"]) .fc-tab.active {
  background: linear-gradient(135deg, rgba(109, 40, 217, 0.12), rgba(8, 145, 178, 0.07));
  border-color: rgba(109, 40, 217, 0.38);
  color: #5b21b6;
}

:global([data-theme="light"]) .fc-icon {
  background: rgba(109, 40, 217, 0.06);
  border-color: rgba(109, 40, 217, 0.11);
}

:global([data-theme="light"]) .fc-item:hover .fc-icon {
  background: rgba(109, 40, 217, 0.11);
  border-color: rgba(109, 40, 217, 0.22);
}

:global([data-theme="light"]) .fc-name {
  color: #1e293b;
}

:global([data-theme="light"]) .fc-desc {
  color: rgba(71, 85, 105, 0.85);
}

:global([data-theme="light"]) .fc-code-box {
  background: rgba(248, 250, 252, 0.9);
  border-color: rgba(109, 40, 217, 0.09);
}

:global([data-theme="light"]) .fc-code-label {
  color: #0369a1;
  border-bottom-color: rgba(109, 40, 217, 0.07);
}

:global([data-theme="light"]) .fc-code { color: #334155 !important; }
:global([data-theme="light"]) .fc-code :global(.rk) { color: #7c3aed; }
:global([data-theme="light"]) .fc-code :global(.rm) { color: #0369a1; }
:global([data-theme="light"]) .fc-code :global(.rs) { color: #15803d; }
:global([data-theme="light"]) .fc-code :global(.rc) { color: #94a3b8; font-style: italic; }
:global([data-theme="light"]) .fc-code :global(.rp) { color: #64748b; }
:global([data-theme="light"]) .fc-code :global(.rn) { color: #b45309; }
:global([data-theme="light"]) .fc-code :global(.rg) { color: #15803d; }
:global([data-theme="light"]) .fc-code :global(.ry) { color: #b45309; }
:global([data-theme="light"]) .fc-code :global(.ro) { color: #94a3b8; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var win = document.getElementById('ra-fc');
    if (!win) return;

    var tabs   = Array.from(win.querySelectorAll('.fc-tab'));
    var panels = Array.from(win.querySelectorAll('.fc-panel'));
    var pfill  = document.getElementById('ra-fc-prog');
    var TOTAL  = tabs.length;
    var DELAY  = 6000;

    var current = 0;
    var paused  = false;
    var timer   = null;

    function goTo(n) {
      var next = ((n % TOTAL) + TOTAL) % TOTAL;

      tabs[current].classList.remove('active');
      tabs[current].setAttribute('aria-selected', 'false');
      panels[current].classList.remove('active');

      tabs[next].classList.add('active');
      tabs[next].setAttribute('aria-selected', 'true');
      panels[next].classList.add('active');

      current = next;
      restartProgress();
    }

    function restartProgress() {
      if (!pfill) return;
      pfill.classList.remove('running');
      void pfill.offsetWidth;
      pfill.classList.add('running');
    }

    function startAutoAdvance() {
      if (timer) clearInterval(timer);
      timer = setInterval(function () {
        if (!paused) goTo(current + 1);
      }, DELAY);
    }

    tabs.forEach(function (tab, i) {
      tab.addEventListener('click', function () {
        goTo(i);
        startAutoAdvance();
      });
    });

    function setPaused(val) {
      paused = val;
      if (pfill) {
        pfill.style.animationPlayState = val ? 'paused' : 'running';
      }
    }

    win.addEventListener('mouseenter', function () { setPaused(true); });
    win.addEventListener('mouseleave', function () { setPaused(false); });
    win.addEventListener('focusin',    function () { setPaused(true); });
    win.addEventListener('focusout',   function () { setPaused(false); });

    restartProgress();
    startAutoAdvance();
  });
</script>
