# Reactive Agents — Example Suite environment template
#
# Copy this file to `.env`, then fill in a key:
#
#   cp .env.example .env
#
# Bun auto-loads `.env` from this directory when you run the suite.
# `.env` is gitignored — your real keys never get committed.
#
# Leave every key blank to run in TEST/offline mode (deterministic, no API
# calls, no key needed):  bun run index.ts --offline
#
# Set ONE key to run the live examples against that provider. The suite
# auto-detects the provider from whichever key is present.

# --- Provider API keys (fill in ONE) ---
# Free Gemini key (recommended): https://ai.google.dev
GOOGLE_API_KEY=
# https://console.anthropic.com
ANTHROPIC_API_KEY=
# https://platform.openai.com
OPENAI_API_KEY=

# --- Optional: pin a specific provider/model for live runs ---
# PROVIDER=gemini
# MODEL=gemini-1.5-flash

# --- Optional: local Ollama (no key needed) ---
# PROVIDER=ollama
# MODEL=cogito:14b
# OLLAMA_ENDPOINT=http://localhost:11434
