{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "tsup.config.base.ts",
    "tsconfig.json",
    "bun.lock",
    ".env.example",
    "package.json"
  ],
  "globalEnv": ["CLEAN"],
  "cacheDir": ".turbo",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "tsup.config.*",
        "tsconfig.json",
        "package.json"
      ],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "test/**",
        "**/*.test.ts",
        "package.json"
      ],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@reactive-agents/docs#build": {
      "cache": false
    }
  }
}
