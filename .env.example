# ── LLM Providers (at least one required) ─────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
LITELLM_API_KEY=
LITELLM_BASE_URL=http://localhost:4000

# Ollama (local — no API key needed)
OLLAMA_ENDPOINT=http://localhost:11434

# ── LLM Behaviour (optional) ──────────────────────────────────────────────────
LLM_DEFAULT_MODEL=claude-sonnet-4-20250514
LLM_MAX_RETRIES=3
LLM_TIMEOUT_MS=30000
LLM_DEFAULT_TEMPERATURE=0.7
# LLM_OBSERVABILITY_VERBOSITY=full   # full | metadata | minimal

# ── Embeddings (Tier 2 memory only) ───────────────────────────────────────────
EMBEDDING_PROVIDER=openai            # openai | ollama
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Web Search ─────────────────────────────────────────────────────────────────
# Provider chain: Tavily → Brave → Serper → DuckDuckGo (no key, limited)
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=               # alternative: BRAVE_API_KEY
SERPER_API_KEY=                     # google.serper.dev — 2500 free queries/month

# ── GitHub Tools (shell-execution tool) ───────────────────────────────────────
GITHUB_TOKEN=

# ── Messaging Integrations ────────────────────────────────────────────────────
SIGNAL_PHONE_NUMBER=

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=

# ── Cortex (local observability dashboard) ────────────────────────────────────
# CORTEX_URL=http://localhost:4321
# CORTEX_LOG=error                  # error | warn | info | debug

# ── Telemetry / Adaptive Calibration (optional — self-hosted) ─────────────────
# One base URL configures both read (/v1/profiles) and write (/v1/reports).
# Default: https://api.reactiveagents.dev (no config needed for cloud).
# REACTIVE_AGENTS_TELEMETRY_BASE_URL=https://your-server.example.com
# Per-endpoint overrides (take precedence over BASE_URL):
# REACTIVE_AGENTS_TELEMETRY_PROFILES_URL=https://your-server.example.com/v1/profiles
# REACTIVE_AGENTS_TELEMETRY_REPORTS_URL=https://your-server.example.com/v1/reports
# Override observations storage directory (default: ~/.reactive-agents/observations/):
# REACTIVE_AGENTS_OBSERVATIONS_DIR=/custom/path/to/observations
    