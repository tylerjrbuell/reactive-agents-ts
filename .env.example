# LLM (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
LITELLM_API_KEY=

# OR

# Ollama (local alternative)
OLLAMA_ENDPOINT=http://localhost:11434
# EMBEDDING_PROVIDER=ollama

# Embeddings (Tier 2 memory only)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Web Search (optional, use if using web-search)
TAVILY_API_KEY=D

# Optional
LLM_DEFAULT_MODEL=claude-sonnet-4-20250514
LLM_MAX_RETRIES=3

# Signal
SIGNAL_PHONE_NUMBER=

#Telegram APID
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=

# Telemetry / Adaptive Calibration (optional — self-hosted deployments)
# One base URL configures both read (/v1/profiles) and write (/v1/reports) endpoints.
# Default: https://api.reactiveagents.dev (no configuration needed for cloud).
# REACTIVE_AGENTS_TELEMETRY_BASE_URL=https://your-server.example.com
# Per-endpoint overrides (take precedence over BASE_URL):
# REACTIVE_AGENTS_TELEMETRY_PROFILES_URL=https://your-server.example.com/v1/profiles
# REACTIVE_AGENTS_TELEMETRY_REPORTS_URL=https://your-server.example.com/v1/reports
# Override observations storage directory (default: ~/.reactive-agents/observations/):
# REACTIVE_AGENTS_OBSERVATIONS_DIR=/custom/path/to/observations